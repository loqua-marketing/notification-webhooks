{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openwork",
  "model": {
    "provider": "ollama",
    "model": "qwen3-coder-30b-tools:latest",
    "base_url": "http://localhost:11434",
    "parameters": {
      "temperature": 0.2,
      "top_p": 0.9,
      "max_tokens": 4096
    }
  },
  "plugins": [],
  "skills": {
    "enabled": true,
    "paths": ["./opencode/skills"]
  }
}